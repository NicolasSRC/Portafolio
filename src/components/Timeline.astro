---
import Section from './Section.astro';
import { experience } from '../data/cv';
---

<Section id="experiencia" eyebrow="// 02. Trayectoria" title="Experiencia profesional">
  <div class="relative">
    <!-- Línea vertical: a la izquierda en móvil, centrada en desktop -->
    <div
      class="absolute top-0 bottom-0 left-4 w-px -translate-x-1/2 bg-gradient-to-b from-[var(--color-accent)] via-[var(--color-border)] to-transparent md:left-1/2"
    >
    </div>

    <div class="space-y-8">
      {
        experience.map((job, i) => {
          const left = i % 2 === 0;
          return (
            <div class="reveal relative">
              {/* Nodo sobre la línea */}
              <div class="absolute left-4 top-6 z-10 -translate-x-1/2 md:left-1/2">
                <div
                  class={`h-4 w-4 rounded-full border-2 border-[var(--color-bg)] ${
                    job.current ? 'bg-[var(--color-accent)] pulse' : 'bg-[var(--color-accent-2)]'
                  }`}
                />
              </div>

              {/* Tarjeta: ocupa media columna alternando lado en desktop */}
              <div
                class={`pl-12 md:pl-0 ${
                  left ? 'md:pr-[calc(50%_+_2rem)]' : 'md:pl-[calc(50%_+_2rem)]'
                }`}
              >
                <details class="card group overflow-hidden" open={i === 0}>
                  <summary class="flex cursor-pointer list-none items-start justify-between gap-3 p-5">
                    <div>
                      {job.current && (
                        <span class="mb-2 inline-flex items-center gap-1.5 rounded-full bg-[var(--color-accent)]/15 px-2.5 py-0.5 font-mono text-[0.65rem] text-[var(--color-accent)]">
                          <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]" /> Actual
                        </span>
                      )}
                      <h3 class="text-lg font-bold leading-snug">{job.role}</h3>
                      <p class="text-sm text-[var(--color-accent-2)]">{job.company}</p>
                      <p class="mt-1 font-mono text-xs text-[var(--color-muted)]">{job.period}</p>
                    </div>
                    <svg
                      class="mt-1 shrink-0 text-[var(--color-muted)] transition-transform group-open:rotate-180"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </summary>

                  <div class="border-t border-[var(--color-border)] p-5">
                    <ul class="space-y-2">
                      {job.highlights.map((h) => (
                        <li class="flex gap-2 text-sm text-[var(--color-muted)]">
                          <span class="mt-1 text-[var(--color-accent)]">▹</span>
                          <span>{h}</span>
                        </li>
                      ))}
                    </ul>
                    <div class="mt-4 flex flex-wrap gap-1.5">
                      {job.tags.map((t) => (
                        <span class="chip">{t}</span>
                      ))}
                    </div>
                  </div>
                </details>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</Section>
