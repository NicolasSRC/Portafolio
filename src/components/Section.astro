---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
}
const { id, eyebrow, title } = Astro.props;
---

<section id={id} class="px-5 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mb-12">
      <p class="font-mono text-sm text-[var(--color-accent)]">{eyebrow}</p>
      <h2 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h2>
      <div class="mt-3 h-px w-24 bg-gradient-to-r from-[var(--color-accent)] to-transparent"></div>
    </div>
    <slot />
  </div>
</section>
