---
import { profile } from '../data/cv';

const initials = profile.name
  .split(' ')
  .map((n) => n[0])
  .slice(0, 2)
  .join('');
---

<section id="top" class="relative flex min-h-screen items-center px-5 pt-24 pb-16">
  <div class="mx-auto grid w-full max-w-6xl items-center gap-12 md:grid-cols-[1.4fr_1fr]">
    <!-- Texto -->
    <div class="reveal">
      <p class="mb-4 font-mono text-sm text-[var(--color-accent)]">
        <span class="cursor-blink">▍</span> Hola, soy
      </p>
      <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl">
        {profile.name}
      </h1>
      <h2 class="mt-2 text-2xl font-bold sm:text-3xl">
        <span class="text-gradient">{profile.role}</span>
      </h2>
      <p class="mt-3 font-mono text-sm text-[var(--color-muted)] sm:text-base">
        {profile.tagline}
      </p>

      <p class="mt-6 max-w-xl text-[var(--color-muted)]">
        Construyo aplicaciones <span class="text-[var(--color-text)]">resistentes y escalables</span>,
        con foco en arquitectura de software, microservicios y buenas prácticas de ingeniería.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="#contacto"
          class="rounded-lg bg-[var(--color-accent)] px-5 py-2.5 font-semibold text-[var(--color-bg)] transition-transform hover:scale-105"
        >
          Contactarme
        </a>
        <a
          href={profile.cvPdf}
          target="_blank"
          class="rounded-lg border border-[var(--color-border)] px-5 py-2.5 font-mono text-sm text-[var(--color-text)] transition-colors hover:border-[var(--color-accent)]"
        >
          ↓ Descargar CV (PDF)
        </a>
      </div>

      <div class="mt-8 flex items-center gap-5 text-[var(--color-muted)]">
        <a href={profile.github} target="_blank" rel="noopener" aria-label="GitHub"
          class="transition-colors hover:text-[var(--color-accent)]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5a11.5 11.5 0 0 0 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
        </a>
        <a href={profile.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"
          class="transition-colors hover:text-[var(--color-accent)]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
        </a>
        <a href={`mailto:${profile.email}`} aria-label="Email"
          class="transition-colors hover:text-[var(--color-accent)]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
        </a>
      </div>
    </div>

    <!-- Foto / avatar -->
    <div class="reveal flex justify-center md:justify-end">
      <div class="relative">
        <div class="absolute -inset-3 rounded-3xl bg-gradient-to-tr from-[var(--color-accent)]/30 to-[var(--color-accent-2)]/30 blur-2xl"></div>
        <div class="relative aspect aspect-[3/4] w-64 overflow-hidden rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] sm:w-72">
          <!-- Si no existe la foto, onerror muestra las iniciales -->
          <img
            src={profile.photo}
            alt={`Foto de ${profile.name}`}
            class="h-full w-full object-cover"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div
            class="hidden h-full w-full items-center justify-center font-mono text-6xl font-bold text-[var(--color-accent)]"
            style="display:none"
          >
            {initials}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Indicador de scroll -->
  <a href="#sobre-mi" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[var(--color-muted)]" aria-label="Bajar">
    <svg class="animate-bounce" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
  </a>
</section>
